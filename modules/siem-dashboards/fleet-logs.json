{
  "uid": "siem-fleet-logs",
  "title": "SIEM-lite - Fleet Logs",
  "tags": ["siem-lite"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log rate by host",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "logs/s", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "queryType": "range", "expr": "sum by (host) (rate({job=\"systemd-journal\"} [$__auto]))", "legendFormat": "{{host}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log rate by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "logs/s", "custom": { "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "queryType": "range", "expr": "sum by (level) (rate({job=\"systemd-journal\"} [$__auto]))", "legendFormat": "{{level}}" }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Recent fleet logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 13, "w": 24, "x": 0, "y": 9 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "queryType": "range", "expr": "{job=\"systemd-journal\"}" }
      ]
    }
  ]
}
