<!--
  remnux — REMnux malware-analysis appliance.
  Built from the official REMnux OVA → vmdk → qcow2 (see ./README.md).
  The OVA is BIOS; keep <os> as-is (no UEFI). Default login: remnux / malware.
    virsh -c qemu:///system define remnux.xml && virsh -c qemu:///system start remnux

  NETWORKING — dual-homed by design (see ../mal-isolated.xml):
    NIC1 mal-isolated  (…b0:03) — PRIMARY analysis net, always up. Air-gapped
                                   host-only net; REMnux runs INetSim here as the
                                   fake-internet/DNS gateway for the victim VM.
                                   Give REMnux a static 10.13.37.10/24 in-guest.
    NIC2 lan-br0       (…b0:13) — LAN/internet, <link state='down'/> BY DEFAULT.
                                   Updates only: `virsh domif-setlink remnux
                                   52:54:00:1a:b0:13 up`, run `remnux upgrade`,
                                   then `… down` again, and snapshot. NEVER raise
                                   it while a live sample is present.
-->
<domain type='kvm'>
  <name>remnux</name>
  <memory unit='GiB'>4</memory>
  <vcpu>2</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features><acpi/><apic/></features>
  <cpu mode='host-passthrough' check='none'/>
  <clock offset='utc'/>
  <on_reboot>restart</on_reboot>
  <devices>
    <!-- REMnux's OVA disk is typically SATA; if it won't boot off virtio, use bus='sata' dev='sda'. -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/remnux.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <!-- NIC1: PRIMARY — isolated analysis network (always up). -->
    <interface type='network'>
      <source network='mal-isolated'/>
      <mac address='52:54:00:1a:b0:03'/>
      <model type='virtio'/>
    </interface>
    <!-- NIC2: LAN/internet for tool updates ONLY — administratively down by default. -->
    <interface type='network'>
      <source network='lan-br0'/>
      <mac address='52:54:00:1a:b0:13'/>
      <model type='virtio'/>
      <link state='down'/>
    </interface>
    <graphics type='vnc' port='-1' listen='127.0.0.1'/>
    <video><model type='virtio'/></video>
    <console type='pty'/>
  </devices>
</domain>
